# Copy this file to `.env` and fill in your secrets.
# `.env` is gitignored — never commit it.
#
# The codebase reads OPENAI_API_KEY first from the environment, then from
# api_keys.json. Either source works; the env var wins if both are set.

OPENAI_API_KEY=sk-your-openai-project-key-here

# Optional: HuggingFace token (only needed if you hit rate limits on
# anonymous downloads of MATH-500 / OlympiadBench / AIME 2025).
# HF_TOKEN=hf_your_token_here
