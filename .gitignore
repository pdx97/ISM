# ── Results: keep only the paper-cited runs tracked explicitly below ────────
# Drop ad-hoc / dated experiment folders; reviewers should reproduce via
# the commands in README.md.
results/math500/
results/aime2025/
results/ablation/
results/comparison/*scratch*/
results/comparison/*_fix*/
results/error_analysis/scratch_*/

# But explicitly KEEP these (override the wildcards above)
!results/comparison/math_updated_50/
!results/comparison/olympiad_updated_50_new/
!results/error_analysis/math_updated_50/
!results/error_analysis/olympiad_50_new/
